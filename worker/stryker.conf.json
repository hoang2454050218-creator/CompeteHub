{
  "$schema": "./node_modules/@stryker-mutator/core/schema/stryker-schema.json",
  "_comment": "Mutation testing configuration. Run: npx stryker run",
  "packageManager": "npm",
  "reporters": ["html", "clear-text", "progress"],
  "testRunner": "jest",
  "coverageAnalysis": "perTest",
  "mutate": [
    "src/scorers/**/*.ts",
    "!src/scorers/**/*.test.ts"
  ],
  "thresholds": {
    "high": 90,
    "low": 75,
    "break": 70
  },
  "jest": {
    "configFile": "jest.config.js",
    "projectType": "custom"
  }
}
