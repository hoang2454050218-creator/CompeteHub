{
  "annotations": { "list": [] },
  "editable": true,
  "graphTooltip": 0,
  "panels": [
    {
      "type": "timeseries",
      "title": "HTTP RPS by status",
      "gridPos": { "x": 0, "y": 0, "w": 12, "h": 8 },
      "targets": [
        { "expr": "sum by (status) (rate(http_requests_total[5m]))", "legendFormat": "{{status}}", "refId": "A" }
      ]
    },
    {
      "type": "timeseries",
      "title": "P50/P95/P99 latency",
      "gridPos": { "x": 12, "y": 0, "w": 12, "h": 8 },
      "targets": [
        { "expr": "histogram_quantile(0.5, sum by (le) (rate(http_request_duration_seconds_bucket[5m])))", "legendFormat": "p50", "refId": "A" },
        { "expr": "histogram_quantile(0.95, sum by (le) (rate(http_request_duration_seconds_bucket[5m])))", "legendFormat": "p95", "refId": "B" },
        { "expr": "histogram_quantile(0.99, sum by (le) (rate(http_request_duration_seconds_bucket[5m])))", "legendFormat": "p99", "refId": "C" }
      ]
    },
    {
      "type": "timeseries",
      "title": "Failed logins by reason",
      "gridPos": { "x": 0, "y": 8, "w": 12, "h": 8 },
      "targets": [
        { "expr": "sum by (reason) (rate(auth_failed_login_total[5m]))", "legendFormat": "{{reason}}", "refId": "A" }
      ]
    },
    {
      "type": "stat",
      "title": "Active WebSocket connections",
      "gridPos": { "x": 12, "y": 8, "w": 6, "h": 4 },
      "targets": [
        { "expr": "sum(websocket_connections)", "refId": "A" }
      ]
    },
    {
      "type": "stat",
      "title": "Leaderboard cache hit ratio (5m)",
      "gridPos": { "x": 18, "y": 8, "w": 6, "h": 4 },
      "targets": [
        { "expr": "sum(rate(leaderboard_cache_total{result=\"hit\"}[5m])) / sum(rate(leaderboard_cache_total[5m]))", "refId": "A" }
      ],
      "fieldConfig": { "defaults": { "unit": "percentunit" } }
    },
    {
      "type": "timeseries",
      "title": "Submission outcomes",
      "gridPos": { "x": 0, "y": 16, "w": 12, "h": 8 },
      "targets": [
        { "expr": "sum by (outcome) (rate(submission_upload_total[5m]))", "legendFormat": "{{outcome}}", "refId": "A" }
      ]
    },
    {
      "type": "timeseries",
      "title": "BullMQ scoring queue depth",
      "gridPos": { "x": 12, "y": 16, "w": 12, "h": 8 },
      "targets": [
        { "expr": "bullmq_queue_depth{queue=\"scoring\"}", "legendFormat": "{{state}}", "refId": "A" }
      ]
    }
  ],
  "refresh": "30s",
  "schemaVersion": 39,
  "tags": ["competehub", "backend"],
  "time": { "from": "now-3h", "to": "now" },
  "title": "CompeteHub — Backend Overview",
  "uid": "competehub-backend",
  "version": 1
}
