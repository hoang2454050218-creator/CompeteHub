# ===========================================
# Competition Platform - Environment Variables
# ===========================================
# Copy this file to .env and fill in real values
# NEVER commit .env to version control

# Database
# In production, add ?sslmode=require&connection_limit=20 for encrypted connections
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/competition_platform
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres          # CHANGE in production - use a strong password
POSTGRES_DB=competition_platform

# Redis
# Production format: redis://:yourpassword@redis:6379
REDIS_URL=redis://localhost:6379
REDIS_PASSWORD=                     # REQUIRED in production - set a strong password

# JWT (MUST change these in production - use `openssl rand -hex 64`)
# Both secrets MUST be at least 32 characters in production
JWT_ACCESS_SECRET=your-access-secret-key-change-in-production
JWT_REFRESH_SECRET=your-refresh-secret-key-change-in-production
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# OAuth
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret
GITHUB_CLIENT_ID=your-github-client-id
GITHUB_CLIENT_SECRET=your-github-client-secret
OAUTH_CALLBACK_URL=http://localhost:3000/api/v1/auth

# MinIO (CHANGE credentials in production)
MINIO_ENDPOINT=localhost
MINIO_PORT=9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_BUCKET=competition-platform
MINIO_USE_SSL=false
# Set to "auto" when using Cloudflare R2; default "us-east-1" for AWS S3 / MinIO
MINIO_REGION=us-east-1

# Email (SMTP)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-app-password
EMAIL_FROM=noreply@competition-platform.com

# App
NODE_ENV=development
PORT=3000
FRONTEND_URL=http://localhost:5173
API_URL=http://localhost:3000

# Worker
WORKER_HEALTH_PORT=3001

# Error Tracking (Sentry - optional but recommended for production)
SENTRY_DSN=
VITE_SENTRY_DSN=

# Frontend (used at build time)
VITE_API_URL=/api/v1
VITE_WS_URL=

# Backup (used by scripts/backup-db.sh — optional for local dev)
# BACKUP_DIR=./backups
# RETENTION_DAYS=7
# BACKUP_ENCRYPTION_KEY=           # Optional: encrypts backups with openssl
# S3_BACKUP_BUCKET=                # Optional: uploads backups to S3
